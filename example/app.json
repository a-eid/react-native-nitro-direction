{
  "expo": {
    "name": "NitroDirectionExample",
    "slug": "nitro-direction-example",
    "version": "0.1.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "nitro-direction-example",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0d10"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.margelo.nitro.layoutdirection.example",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b0d10"
      },
      "package": "com.margelo.nitro.layoutdirection.example"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "69725f6a-abb0-4a6b-966a-6eaeeeb4897c"
      }
    }
  }
}
