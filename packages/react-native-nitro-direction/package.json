{
  "name": "react-native-nitro-direction",
  "version": "0.1.1",
  "description": "Flip a React Native app between LTR and RTL at runtime — no restart, no reload, no remount. Native iOS + Android, built on Nitro Modules.",
  "main": "lib/index",
  "module": "lib/index",
  "types": "lib/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "!src/__tests__",
    "react-native.config.js",
    "lib",
    "nitrogen",
    "android/build.gradle",
    "android/gradle.properties",
    "android/CMakeLists.txt",
    "android/src",
    "cpp",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "ios/**/*.cpp",
    "ios/**/*.swift",
    "LayoutDirection.podspec",
    "nitro.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf android/build node_modules/**/android/build lib",
    "test": "jest",
    "typescript": "tsc",
    "specs": "tsc --noEmit && nitrogen --logLevel=\"debug\"",
    "prepublishOnly": "tsc && nitrogen --logLevel=\"debug\""
  },
  "keywords": [
    "react-native",
    "nitro-modules",
    "rtl",
    "ltr",
    "i18n",
    "internationalization",
    "localization",
    "arabic",
    "hebrew",
    "bidi",
    "layout-direction",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-eid/react-native-nitro-direction.git"
  },
  "author": "Ahmed Eid (https://github.com/a-eid)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/a-eid/react-native-nitro-direction/issues"
  },
  "homepage": "https://github.com/a-eid/react-native-nitro-direction#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "^19.2.15",
    "jest": "^29.7.0",
    "nitrogen": "*",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-nitro-modules": "*",
    "ts-jest": "^29.4.4",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*"
  }
}
